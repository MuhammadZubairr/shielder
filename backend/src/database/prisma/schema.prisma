generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                  @id @default(uuid())
  email                   String                  @unique
  createdAt               DateTime                @default(now()) @map("created_at")
  createdBy               String?                 @map("created_by")
  deletedAt               DateTime?               @map("deleted_at")
  emailVerified           Boolean                 @default(false) @map("email_verified")
  failedLoginAttempts     Int                     @default(0) @map("failed_login_attempts")
  isActive                Boolean                 @default(true) @map("is_active")
  lastLoginAt             DateTime?               @map("last_login_at")
  lastPasswordChange      DateTime?               @map("last_password_change")
  lockedUntil             DateTime?               @map("locked_until")
  passwordHash            String                  @map("password_hash")
  resetToken              String?                 @map("reset_token")
  resetTokenExpiry        DateTime?               @map("reset_token_expiry")
  updatedAt               DateTime                @updatedAt @map("updated_at")
  updatedBy               String?                 @map("updated_by")
  verificationToken       String?                 @map("verification_token")
  verificationTokenExpiry DateTime?               @map("verification_token_expiry")
  role                    UserRole                @default(USER)
  status                  UserStatus              @default(PENDING)
  lastLoginIp             String?                 @map("last_login_ip")
  auditLogs               AuditLog[]
  carts                   Cart[]
  expenses                Expense[]
  notificationPreferences NotificationPreference?
  triggeredNotifications  Notification[]          @relation("NotificationTriggerer")
  notifications           Notification[]
  orders                  Order[]
  payments                Payment[]
  products                Product[]
  quotationsCreated       Quotation[]             @relation("QuotationCreator")
  refreshTokens           RefreshToken[]
  profile                 UserProfile?

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([isActive])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("users")
}

model RefreshToken {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  tokenHash     String    @unique @map("token_hash")
  deviceInfo    String?   @map("device_info")
  ipAddress     String?   @map("ip_address")
  expiresAt     DateTime  @map("expires_at")
  isRevoked     Boolean   @default(false) @map("is_revoked")
  revokedAt     DateTime? @map("revoked_at")
  revokedReason String?   @map("revoked_reason")
  createdAt     DateTime  @default(now()) @map("created_at")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@index([isRevoked])
  @@map("refresh_tokens")
}

model UserProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  preferences       Json?
  address           String?
  companyName       String?  @default("Shielder") @map("company_name")
  createdAt         DateTime @default(now()) @map("created_at")
  fullName          String?  @map("full_name")
  phoneNumber       String?  @map("phone_number")
  preferredLanguage String   @default("en") @map("preferred_language")
  profileImage      String?  @map("profile_image")
  taxId             String?  @map("tax_id")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Category {
  id                      String                    @id @default(uuid())
  createdAt               DateTime                  @default(now()) @map("created_at")
  image                   String?
  isActive                Boolean                   @default(true) @map("is_active")
  updatedAt               DateTime                  @updatedAt @map("updated_at")
  brands                  brands[]
  category_spec_templates category_spec_templates[]
  translations            CategoryTranslation[]
  products                Product[]
  subcategories           Subcategory[]

  @@map("categories")
}

model CategoryTranslation {
  id          String   @id @default(uuid())
  categoryId  String
  locale      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@map("category_translations")
}

model Subcategory {
  id                      String                    @id @default(uuid())
  categoryId              String                    @map("category_id")
  createdAt               DateTime                  @default(now()) @map("created_at")
  image                   String?
  isActive                Boolean                   @default(true) @map("is_active")
  updatedAt               DateTime                  @updatedAt @map("updated_at")
  brands                  brands[]
  category_spec_templates category_spec_templates[]
  products                Product[]
  category                Category                  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  translations            SubcategoryTranslation[]

  @@map("subcategories")
}

model SubcategoryTranslation {
  id            String      @id @default(uuid())
  subcategoryId String
  locale        String
  name          String
  description   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  subcategory   Subcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)

  @@unique([subcategoryId, locale])
  @@map("subcategory_translations")
}

model Product {
  id                    String                 @id @default(uuid())
  categoryId            String                 @map("categoryId")
  createdAt             DateTime               @default(now()) @map("createdAt")
  updatedAt             DateTime               @updatedAt @map("updatedAt")
  price                 Decimal                @db.Decimal(10, 2)
  stock                 Int                    @default(0)
  subcategoryId         String                 @map("subcategoryId")
  isActive              Boolean                @default(true) @map("is_active")
  brandId               String?                @map("brandId")
  minimumStockThreshold Int                    @default(5) @map("minimum_stock_threshold")
  mainImage             String?                @map("main_image")
  sku                   String?
  status                ProductStatus          @default(PENDING)
  supplierId            String?                @map("supplier_id")
  filterNumber          String?                @map("filter_number")
  alternateNumbers      String?                @map("alternate_numbers")
  filterType            String?                @map("filter_type")
  material              String?
  dimensions            String?
  cartItems             CartItem[]
  orderItems            OrderItem[]
  attachments           ProductAttachment[]
  specifications        ProductSpecification[]
  translations          ProductTranslation[]
  product_variants      product_variants[]
  brand                 brands?                @relation(fields: [brandId], references: [id])
  category              Category               @relation(fields: [categoryId], references: [id])
  subcategory           Subcategory            @relation(fields: [subcategoryId], references: [id])
  supplier              User?                  @relation(fields: [supplierId], references: [id])
  quotationItems        QuotationItem[]
  stockHistory          stock_history[]

  @@index([categoryId])
  @@index([subcategoryId])
  @@index([brandId])
  @@index([supplierId])
  @@index([price])
  @@index([stock])
  @@index([status])
  @@index([minimumStockThreshold])
  @@index([isActive])
  @@index([createdAt])
  @@map("products")
}

model ProductTranslation {
  id          String   @id @default(uuid())
  productId   String
  locale      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
  @@map("product_translations")
}

model ProductSpecification {
  id         String   @id @default(uuid())
  created_at DateTime @default(now())
  product_id String
  spec_key   String
  spec_value String
  updated_at DateTime
  products   Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, spec_key])
  @@map("product_specifications")
}

model ProductAttachment {
  id        String         @id @default(uuid())
  productId String
  type      AttachmentType
  fileName  String
  fileUrl   String
  mimeType  String
  size      Int
  language  String         @default("en")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_attachments")
}

model Order {
  id                 String          @id @default(uuid())
  total              Decimal         @db.Decimal(10, 2)
  createdAt          DateTime        @default(now()) @map("created_at")
  customerName       String?         @map("customer_name")
  notes              String?
  orderNumber        String          @unique @map("order_number")
  paymentMethod      String?         @map("payment_method")
  paymentStatus      PaymentStatus   @default(UNPAID) @map("payment_status")
  phoneNumber        String?         @map("phone_number")
  shippingAddress    String?         @map("shipping_address")
  subtotal           Decimal         @db.Decimal(10, 2)
  tax                Decimal         @default(0) @db.Decimal(10, 2)
  updatedAt          DateTime        @updatedAt @map("updated_at")
  userId             String          @map("user_id")
  status             OrderStatus     @default(PENDING)
  orderItems         OrderItem[]
  users              User            @relation(fields: [userId], references: [id])
  payments           Payment[]
  convertedQuotation Quotation?
  stockHistory       stock_history[] @relation("OrderToStockHistory")

  @@index([orderNumber])
  @@index([status])
  @@index([userId])
  @@map("orders")
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String        @map("order_id")
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod
  status        PaymentStatus @default(UNPAID)
  transactionId String?       @unique @map("transaction_id")
  notes         String?
  recordedBy    String?       @map("recorded_by")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  recorder      User?         @relation(fields: [recordedBy], references: [id])

  @@index([orderId])
  @@index([status])
  @@index([transactionId])
  @@map("payments")
}

model Expense {
  id          String   @id @default(uuid())
  amount      Decimal  @db.Decimal(10, 2)
  category    String
  description String?
  date        DateTime @default(now())
  recordedBy  String?  @map("recorded_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  recorder    User?    @relation(fields: [recordedBy], references: [id])

  @@index([category])
  @@index([date])
  @@map("expenses")
}

model OrderItem {
  id         String            @id @default(uuid())
  quantity   Int
  orderId    String            @map("order_id")
  productId  String            @map("product_id")
  totalPrice Decimal           @map("total_price") @db.Decimal(10, 2)
  unitPrice  Decimal           @map("unit_price") @db.Decimal(10, 2)
  variantId  String?           @map("variant_id")
  order      Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product           @relation(fields: [productId], references: [id])
  variant    product_variants? @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  createdAt  DateTime @default(now())
  changes    Json?
  ipAddress  String?
  userAgent  String?
  user       User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @map("user_id")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  status    CartStatus @default(ACTIVE)
  items     CartItem[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("carts")
}

model SystemSettings {
  id                             String    @id @default("CURRENT")
  systemName                     String    @default("Shielder") @map("system_name")
  companyName                    String    @default("Shielder Digital") @map("company_name")
  companyLogo                    String?   @map("company_logo")
  companyEmail                   String?   @map("company_email")
  companyPhone                   String?   @map("company_phone")
  companyAddress                 String?   @map("company_address")
  currency                       String    @default("USD")
  timezone                       String    @default("UTC")
  dateFormat                     String    @default("YYYY-MM-DD") @map("date_format")
  language                       String    @default("en")
  defaultOrderStatus             String    @default("PENDING") @map("default_order_status")
  autoCompleteOrderAfterPayment  Boolean   @default(true) @map("auto_complete_order_after_payment")
  allowPartialPayment            Boolean   @default(false) @map("allow_partial_payment")
  allowOrderCancellation         Boolean   @default(true) @map("allow_order_cancellation")
  autoCancelUnpaidOrdersHours    Int?      @map("auto_cancel_unpaid_orders_hours")
  paymentMethodsEnabled          Json?     @map("payment_methods_enabled")
  onlinePaymentEnabled           Boolean   @default(true) @map("online_payment_enabled")
  paymentTestMode                Boolean   @default(true) @map("payment_test_mode")
  paymentGatewayApiKey           String?   @map("payment_gateway_api_key")
  paymentGatewaySecretKey        String?   @map("payment_gateway_secret_key")
  paymentWebhookUrl              String?   @map("payment_webhook_url")
  enableEmailNotifications       Boolean   @default(true) @map("enable_email_notifications")
  enableLowStockAlerts           Boolean   @default(true) @map("enable_low_stock_alerts")
  lowStockThreshold              Int       @default(5) @map("low_stock_threshold")
  enableOrderStatusNotifications Boolean   @default(true) @map("enable_order_status_notifications")
  enablePaymentNotifications     Boolean   @default(true) @map("enable_payment_notifications")
  roleNotificationMappings       Json?     @map("role_notification_mappings")
  passwordMinLength              Int       @default(8) @map("password_min_length")
  maxLoginAttempts               Int       @default(5) @map("max_login_attempts")
  accountLockDurationMinutes     Int       @default(30) @map("account_lock_duration_minutes")
  sessionTimeoutMinutes          Int       @default(60) @map("session_timeout_minutes")
  enableTwoFactorAuth            Boolean   @default(false) @map("enable_two_factor_auth")
  forceStrongPasswords           Boolean   @default(true) @map("force_strong_passwords")
  lastBackupDate                 DateTime? @map("last_backup_date")
  autoBackupSchedule             String?   @map("auto_backup_schedule")
  updatedAt                      DateTime  @updatedAt @map("updated_at")
  updatedBy                      String?   @map("updated_by")

  @@map("system_settings")
}

model SystemConfigSnapshot {
  id          String   @id @default(uuid())
  config      Json
  version     Int
  description String?
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("system_config_snapshots")
}

model CartItem {
  id          String   @id @default(uuid())
  cartId      String   @map("cart_id")
  productId   String   @map("product_id")
  quantity    Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  priceAtTime Decimal  @map("price_at_time") @db.Decimal(10, 2)
  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@map("cart_items")
}

model brand_translations {
  id          String   @id
  brandId     String
  locale      String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  Brand       brands   @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, locale])
}

model category_spec_templates {
  id             String       @id
  category_id    String
  subcategory_id String?
  spec_key       String
  is_required    Boolean      @default(false)
  created_at     DateTime     @default(now())
  updated_at     DateTime
  categories     Category     @relation(fields: [category_id], references: [id], onDelete: Cascade)
  subcategories  Subcategory? @relation(fields: [subcategory_id], references: [id], onDelete: Cascade)

  @@unique([category_id, subcategory_id, spec_key])
}

model Notification {
  id            String           @id @default(uuid())
  title         String
  message       String
  isRead        Boolean          @default(false) @map("is_read")
  createdAt     DateTime         @default(now()) @map("created_at")
  deletedAt     DateTime?        @map("deleted_at")
  metadata      Json?
  module        String?
  relatedId     String?          @map("related_id")
  roleTarget    UserRole?        @map("role_target")
  triggeredBy   String?          @map("triggered_by")
  triggeredById String?          @map("triggered_by_id")
  userId        String?          @map("user_id")
  type          NotificationType
  triggerer     User?            @relation("NotificationTriggerer", fields: [triggeredById], references: [id])
  user          User?            @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([isRead])
  @@index([roleTarget])
  @@index([userId])
  @@map("notifications")
}

model NotificationPreference {
  id           String  @id @default(uuid())
  userId       String  @unique @map("user_id")
  lowStock     Boolean @default(true) @map("low_stock")
  orderUpdates Boolean @default(true) @map("order_updates")
  payments     Boolean @default(true)
  newUser      Boolean @default(true) @map("new_user")
  email        Boolean @default(true)
  inApp        Boolean @default(true) @map("in_app")
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model brands {
  id                 String               @id
  name               String
  logo               String?
  categoryId         String?
  subcategoryId      String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  brand_translations brand_translations[]
  categories         Category?            @relation(fields: [categoryId], references: [id])
  subcategories      Subcategory?         @relation(fields: [subcategoryId], references: [id])
  products           Product[]
}

model product_variants {
  id          String      @id
  product_id  String
  name        String
  sku         String      @unique
  price       Decimal?    @db.Decimal(10, 2)
  stock       Int         @default(0)
  created_at  DateTime    @default(now())
  updated_at  DateTime
  order_items OrderItem[]
  products    Product     @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

model stock_history {
  id           String          @id
  product_id   String
  order_id     String?
  quantity     Int
  type         StockChangeType
  note         String?
  created_at   DateTime        @default(now())
  performed_by String?
  product_name String
  order        Order?          @relation("OrderToStockHistory", fields: [order_id], references: [id])
  product      Product         @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([order_id])
  @@index([product_id])
  @@index([type])
}

model Quotation {
  id               String              @id @default(uuid())
  quotationNumber  String              @unique @map("quotation_number")
  status           QuotationStatus     @default(DRAFT)
  customerName     String              @map("customer_name")
  customerEmail    String              @map("customer_email")
  customerPhone    String?             @map("customer_phone")
  customerAddress  String?             @map("customer_address")
  companyName      String?             @map("company_name")
  subtotal         Decimal             @db.Decimal(10, 2)
  discount         Decimal             @default(0) @db.Decimal(10, 2)
  tax              Decimal             @default(0) @db.Decimal(10, 2)
  total            Decimal             @db.Decimal(10, 2)
  notes            String?
  terms            String?
  quotationDate    DateTime            @default(now()) @map("quotation_date")
  expiryDate       DateTime            @map("expiry_date")
  createdById      String              @map("created_by_id")
  convertedOrderId String?             @unique @map("converted_order_id")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  activities       QuotationActivity[]
  items            QuotationItem[]
  convertedOrder   Order?              @relation(fields: [convertedOrderId], references: [id])
  createdBy        User                @relation("QuotationCreator", fields: [createdById], references: [id])

  @@index([status])
  @@index([createdById])
  @@index([expiryDate])
  @@index([quotationNumber])
  @@map("quotations")
}

model QuotationItem {
  id          String    @id @default(uuid())
  quotationId String    @map("quotation_id")
  productId   String    @map("product_id")
  productName String    @map("product_name")
  quantity    Int
  unitPrice   Decimal   @map("unit_price") @db.Decimal(10, 2)
  discount    Decimal   @default(0) @db.Decimal(10, 2)
  totalPrice  Decimal   @map("total_price") @db.Decimal(10, 2)
  product     Product   @relation(fields: [productId], references: [id])
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@index([productId])
  @@map("quotation_items")
}

model QuotationActivity {
  id          String                @id @default(uuid())
  quotationId String                @map("quotation_id")
  action      QuotationActivityType
  performedBy String                @map("performed_by")
  note        String?
  createdAt   DateTime              @default(now()) @map("created_at")
  quotation   Quotation             @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@map("quotation_activities")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  USER
  SUPPLIER
  STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
}

enum DataType {
  NUMBER
  TEXT
  BOOLEAN
}

enum AttachmentType {
  IMAGE
  DATASHEET
  MANUAL
  CERTIFICATE
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
}

enum NotificationType {
  LOW_STOCK
  ORDER_CREATED
  ORDER_COMPLETED
  PAYMENT_SUCCESSFUL
  PAYMENT_FAILED
  NEW_USER_CREATED
  REFUND_ISSUED
  SYSTEM_ALERT
  QUOTATION_APPROVED
  QUOTATION_EXPIRED
  QUOTATION_CREATED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CREDIT_CARD
  DEBIT_CARD
  ONLINE_GATEWAY
  WALLET
}

enum PaymentStatus {
  PAID
  UNPAID
  PENDING
  FAILED
  REFUNDED
  PARTIALLY_PAID
  PARTIALLY_REFUNDED
}

enum ProductStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
}

enum StockChangeType {
  ORDER_COMPLETED
  ORDER_CANCELLED
  MANUAL_ADJUSTMENT
  RESTOCK
}

enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}

enum QuotationActivityType {
  CREATED
  EDITED
  SENT
  VIEWED
  APPROVED
  REJECTED
  CONVERTED
  DELETED
  EXPIRED
  REACTIVATED
}
